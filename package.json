{
  "name": "jinmarket",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:cert": "powershell -ExecutionPolicy Bypass -File scripts/generate-dev-cert.ps1",
    "dev:api": "npm run dev --workspace @jinmarket/api",
    "dev:shop": "npm run dev --workspace @jinmarket/shop-web",
    "dev:admin": "npm run dev --workspace @jinmarket/admin-web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
